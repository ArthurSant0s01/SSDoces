# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/{project-id}/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous key (public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Supabase service role key (for server-side operations only)
# NEVER expose this in the browser - keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Public website URL used in checkout links and SEO
VITE_SITE_URL=https://ssdoces.pt

# Email notifications via Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=noreply@ssdoces.pt
SSDOCES_ADMIN_EMAIL=sosdoces.pt@gmail.com
